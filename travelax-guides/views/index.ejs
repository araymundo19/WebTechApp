<%- include('partials/header') %>
<%- include('partials/nav') %>

<section class="hero">
    <h2>Your Journey Starts Here</h2>
    <p>Discover amazing destinations in the Philippines and across Asia.</p>
    <button type="button" class="btn btn-primary btn-lg mt-3" data-bs-toggle="modal" data-bs-target="#welcomeModal">
        Start Exploring!
    </button>
</section>

<main class="container">
    <section class="destinations-ph my-5">
        <h2 class="text-center mb-4">Explore Philippine Gems</h2>
        <div class="row">
            <% const phDestinations = places.filter(p => p.region === 'Philippines'); %>
            
            <% if (phDestinations.length > 0) { %>
                <% phDestinations.forEach(place => { %>
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm">
                            <img src="<%= place.image ? '/images/' + place.image : '/images/placeholder.png' %>" 
                             class="card-img-top" 
                             style="height: 200px; object-fit: cover;" 
                             alt="<%= place.name %>"
                             onerror="this.src='/images/placeholder.png';">
                            <div class="card-body">
                                <h3 class="card-title h5"><%= place.name %></h3>
                                <p class="card-text text-muted"><%= place.description %></p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <a href="#" class="btn btn-primary btn-sm">Discover</a>
                                    <a href="/destinations/edit/<%= place._id %>" class="btn btn-outline-primary btn-sm">Edit</a>
                                    <form action="/destinations/delete/<%= place._id %>" method="POST">
                                        <button class="btn btn-outline-danger btn-sm">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-center">No Philippine destinations added yet.</p>
            <% } %>
        </div>
    </section>

    <hr>

    <section class="destinations-asia my-5">
        <h2 class="text-center mb-4">Asia & Beyond</h2>
        <div class="row">
            <% const asiaDestinations = places.filter(p => p.region === 'Asia'); %>
            
            <% if (asiaDestinations.length > 0) { %>
                <% asiaDestinations.forEach(place => { %>
                    <div class="col-lg-6 col-md-6 mb-4"> <div class="card h-100 shadow-sm">
                        <img src="<%= place.image ? '/images/' + place.image : '/images/placeholder.png' %>" 
                         class="card-img-top" 
                         style="height: 200px; object-fit: cover;" 
                         alt="<%= place.name %>"
                         onerror="this.src='/images/placeholder.png';">
                            <div class="card-body">
                                <h3 class="card-title h5 text-primary"><%= place.name %></h3>
                                <p class="card-text"><%= place.description %></p>
                                <a href="/destinations/edit/<%= place._id %>" class="btn btn-outline-primary btn-sm">Edit</a>
                                <form action="/destinations/delete/<%= place._id %>" method="POST">
                                    <button class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-center">No Asian destinations added yet.</p>
            <% } %>
        </div>
    </section>
</main>

<%- include('partials/footer') %>